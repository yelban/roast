{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {}
    },
    "graphiti": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "--header",
        "X-Group-ID: roast",
        "http://127.0.0.1:8001/sse?group_id=roast"
      ]
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": [
        "serve",
        "--mcp"
      ]
    }
  }
}
